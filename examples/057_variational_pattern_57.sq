# Generated variational circuit pattern 57
simulate(5, engine="sparse") {
    let q = quantum_register(5)
    H_all()
    # layer 0
    Rx(q[0], PI / 3)
    Ry(q[1], PI / 4)
    Rz(q[2], PI / 5)
    Rx(q[3], PI / 6)
    Ry(q[4], PI / 7)
    RZZ(q[0], q[1], PI / 5)
    CNOT(q[1], q[2])
    RZZ(q[2], q[3], PI / 7)
    CNOT(q[3], q[4])
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

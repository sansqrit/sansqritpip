# controlled_rotation_bank example 88
simulate(4, engine="sharded", n_shards=4, workers=2) {
    let q = quantum_register(4)
    H(q[0])
    for i in range(1, 4) {
        CRz(q[0], q[i], PI / (i + 1))
        CRx(q[0], q[i], PI / (i + 2))
    }
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

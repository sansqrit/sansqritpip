# Generated variational circuit pattern 60
simulate(3, engine="sparse") {
    let q = quantum_register(3)
    H_all()
    # layer 0
    Rx(q[0], PI / 6)
    Ry(q[1], PI / 7)
    Rz(q[2], PI / 8)
    CNOT(q[0], q[1])
    RZZ(q[1], q[2], PI / 4)
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

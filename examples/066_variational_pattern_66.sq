# Generated variational circuit pattern 66
simulate(4, engine="sparse") {
    let q = quantum_register(4)
    H_all()
    # layer 0
    Rx(q[0], PI / 5)
    Ry(q[1], PI / 6)
    Rz(q[2], PI / 7)
    Rx(q[3], PI / 8)
    CNOT(q[0], q[1])
    RZZ(q[1], q[2], PI / 5)
    CNOT(q[2], q[3])
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

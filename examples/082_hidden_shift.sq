# hidden_shift example 82
simulate(6, engine="sharded", n_shards=4, workers=2) {
    let q = quantum_register(6)
    H_all()
    for i in range(6) {
        Rz(q[i], PI / (i + 2))
    }
    for i in range(5) {
        CNOT(q[i], q[i + 1])
    }
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

# 124-qubit low-entanglement molecule feature map using MPS.
simulate(124, engine="mps", max_bond_dim=32, cutoff=1e-12) {
    q = quantum_register(124)
    for i in range(0, 12) {
        Ry(q[i], 0.01 * (i + 1))
    }
    for i in range(0, 11) {
        CNOT(q[i], q[i + 1])
    }
    print("drug discovery backend", sansqrit_backends())
}

# Generated variational circuit pattern 54
simulate(7, engine="sparse") {
    let q = quantum_register(7)
    H_all()
    # layer 0
    Rx(q[0], PI / 7)
    Ry(q[1], PI / 8)
    Rz(q[2], PI / 2)
    Rx(q[3], PI / 3)
    Ry(q[4], PI / 4)
    Rz(q[5], PI / 5)
    Rx(q[6], PI / 6)
    CNOT(q[0], q[1])
    RZZ(q[1], q[2], PI / 3)
    CNOT(q[2], q[3])
    RZZ(q[3], q[4], PI / 5)
    CNOT(q[4], q[5])
    RZZ(q[5], q[6], PI / 7)
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

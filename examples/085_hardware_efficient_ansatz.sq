# hardware_efficient_ansatz example 85
simulate(5, engine="sharded", n_shards=4, workers=2) {
    let q = quantum_register(5)
    for layer in range(3) {
        for i in range(5) {
            Ry(q[i], PI / (layer + i + 2))
            Rz(q[i], PI / (layer + i + 3))
        }
        for i in range(4) {
            CNOT(q[i], q[i + 1])
        }
    }
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

# Generated variational circuit pattern 55
simulate(3, engine="sparse") {
    let q = quantum_register(3)
    H_all()
    # layer 0
    Ry(q[0], PI / 8)
    Rz(q[1], PI / 2)
    Rx(q[2], PI / 3)
    RZZ(q[0], q[1], PI / 3)
    CNOT(q[1], q[2])
    # layer 1
    Rz(q[0], PI / 2)
    Rx(q[1], PI / 3)
    Ry(q[2], PI / 4)
    RZZ(q[0], q[1], PI / 3)
    CNOT(q[1], q[2])
    print(engine_nnz())
    print(measure_all(q, shots=128))
}

# Generated variational circuit pattern 42
simulate(5, engine="sparse") {
    let q = quantum_register(5)
    H_all()
    # layer 0
    Rx(q[0], PI / 2)
    Ry(q[1], PI / 3)
    Rz(q[2], PI / 4)
    Rx(q[3], PI / 5)
    Ry(q[4], PI / 6)
    CNOT(q[0], q[1])
    RZZ(q[1], q[2], PI / 6)
    CNOT(q[2], q[3])
    RZZ(q[3], q[4], PI / 3)
    print(engine_nnz())
    print(measure_all(q, shots=128))
}
